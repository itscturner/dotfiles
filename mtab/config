{
  "options": {
    "showOptionsButton": true
  },
  "user": {
    "name": "cturner"
  },
  "title": {
    "defaultTitle": "cturner",
    "dynamic": {
      "enabled": true
    },
    "faviconType": "custom"
  },
  "message": {
    "enabled": true,
    "font": {
      "type": "default",
      "custom": ""
    },
    "textColor": "#ffffff",
    "textSize": 3.75,
    "type": "time-12",
    "customText": "your custom text",
    "weather": {
      "unitsType": "f"
    }
  },
  "wallpaper": {
    "type": "url",
    "enabled": true,
    "url": "./wallpapers/default.png",
    "filters": {
      "brightness": ".8",
      "blur": "0px"
    }
  },
  "ui": {
    "style": "glass",
    "glassColor": "#ffffff20",
    "blurStrength": "32px",
    "foregroundColor": "#262626",
    "backgroundColor": "#171717",
    "highlightColor": "#ffffff20",
    "cornerStyle": "round",
    "customCSS": ""
  },
  "animations": {
    "enabled": true,
    "bookmarkTiming": "left",
    "initialType": "animate-grow-scale",
    "searchType": "animate-page-shrink",
    "bookmarkType": "animate-page-up"
  },
  "search": {
    "enabled": true,
    "font": {
      "type": "default",
      "custom": ""
    },
    "textColor": "#ffffff",
    "placeholderText": "search...",
    "bookmarkPlaceholderText": "find bookmark...",
    "placeholderTextColor": "#a1a1aa",
    "searchIconColor": "#ffffff",
    "bookmarkIconColor": "#3b82f6",
    "selectIconColor": "#f59e0b",
    "engine": "google",
    "useCustomEngine": false,
    "customEngineURL": "",
    "focusedBorderColor": "#ffffff",
    "assist": {
      "date": true,
      "math": true,
      "definitions": true,
      "conversions": true
    }
  },
  "hotkeys": {
    "enabled": true,
    "activationKey": " ",
    "closePageKey": "q",
    "searchBookmarksKey": "s"
  },
  "bookmarks": {
    "type": "user-defined",
    "showBookmarkNames": false,
    "numberKeys": false,
    "lineOrientation": "top",
    "defaultFolderIconType": "ri-folder-fill",
    "userDefinedCols": 5,
    "userDefined": [
      {
        "color": "#04a5e5",
        "fill": "",
        "iconColor": "#ffffff",
        "iconType": "nf-cod-mail",
        "name": "GMail",
        "type": "bookmark",
        "url": "https://mail.google.com/"
      },
      {
        "color": "#bcc0cc",
        "fill": "",
        "iconColor": "#ffffff",
        "iconType": "ri-github-fill",
        "name": "github",
        "type": "bookmark",
        "url": "https://github.com"
      },
      {
        "color": "#d20f39",
        "fill": "",
        "iconColor": "#ffffff",
        "iconType": "ri-youtube-fill",
        "name": "youtube",
        "type": "bookmark",
        "url": "https://youtube.com"
      },
      {
        "color": "#74aa9c",
        "fill": "",
        "iconColor": "#ffffff",
        "iconType": "ri-openai-fill",
        "name": "chatgpt",
        "type": "bookmark",
        "url": "https://chatgpt.com"
      },
      {
        "color": "#dc8a78",
        "fill": "",
        "iconColor": "#ffffff",
        "iconType": "nf-md-alpha_w",
        "name": "Wired",
        "type": "bookmark",
        "url": "https://www.wired.com/"
      }
    ],
    "defaultBlockyCols": 4,
    "defaultBlockyColorType": "custom",
    "defaultBlockyColor": "#ffffff",
    "bookmarksLocationFirefox": "toolbar",
    "defaultFaviconSource": "google"
  },
  "extras": {
    "snow": {
      "enabled": "winter"
    }
  }
}
