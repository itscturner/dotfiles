[github]
  user = itscturner

[core]
  editor = nvim
  autocrlf = input

[alias]
  aliases = config --get-regexo '^alias\\.'
  br = branch -av
  cam = commit -am

[color]
  ui = true
  branch = auto
  diff = auto
  status = auto

[color "branch"]
  current = blue reverse
  local = green bold
  remote = yellow bold

[color "status"]
  branch = blue bold
  added = green bold
  changed = yellow bold
  untracked = red blink

[color "diff"]
  old = red bold
  new = green bold

